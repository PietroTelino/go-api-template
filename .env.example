# ========================
# Server
# ========================
PORT=3333

# ========================
# Database (PostgreSQL)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=go-api-template
DB_USER=postgres
DB_PASSWORD=

# ========================
# JWT
# ========================
JWT_SECRET=
JWT_EXPIRES_IN_SECONDS=900

JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# ========================
# Email (SMTP)
# ========================
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# ========================
# Frontend (CORS)
# ========================
FRONTEND_URL=http://localhost:5173

# ========================
# Seed (GOD user)
# ========================
GOD_EMAIL=god@god.com
GOD_PASSWORD=

# ========================
# Password reset
# ========================
PASSWORD_RESET_EXPIRES_MS=3600000